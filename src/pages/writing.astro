    items: [
      {
        title: 'Malware Attacks the Software Update Process',
        url: 'http://esj.com/articles/2009/12/01/malware-software-updates.aspx',
        venue: 'Enterprise Systems Journal',
      },
    ],
  },
  {
    year: 2008,
    items: [
      {
        title: 'The Dangers of Web 2.0',
        url: 'http://www.securitymattersmag.com/security-matters-magazine-article-detail.php?id=331',
        venue: 'Security Matters Magazine',
      },
      {
        title: 'Web 2.0: Attack of the JavaScript Malware',
        url: 'http://www.scmagazine.com/web-20-attack-of-the-javascript-malware/article/113132/',
        venue: 'SC Magazine US',
      },
    ],
  },
  {
    year: 2007,
    items: [{ title: 'Shellcodes Evolution', venue: 'Hakin9 Magazine, Issue 1 (January)' }],
  },
  {
    year: 2006,
    items: [
      {
        title: 'Exploiting with linux-gate.so.1',
        url: 'http://www.exploit-db.com/papers/13187/',
        venue: 'NewOrder Newsletter, Issue 13',
      },
    ],
  },
  {
    year: 2005,
    items: [
      {
        title: 'Linux Improvised Userland Scheduler Virus',
        url: 'http://www.uninformed.org/?v=3&a=6',
        venue: 'Uninformed Journal, Volume 3',
      },
      {
        title: 'Smack the Stack (Advanced Buffer Overflow Methods)',
        url: 'http://events.ccc.de/congress/2005/fahrplan/attachments/539-Paper_AdvancedBufferOverflowMethods.pdf',
        venue: 'Proceedings of 22C3',
      },
      {
        title: 'Reverse Engineering with LD_PRELOAD',
        url: 'http://securityvulns.com/articles/reveng/',
