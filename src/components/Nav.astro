---
import ThemeToggleButton from './ThemeToggleButton.svelte';
const { current = '' } = Astro.props;
---

<style>
  nav {
    align-items: center;
    display: flex;
    flex: 1;
    font-family: 'Web437 IBM VGA 8x16', monospace;
    -webkit-font-smoothing: none;
    -moz-osx-font-smoothing: unset;
    font-weight: normal;
    justify-content: flex-end;
    text-transform: uppercase;
  }

  a {
    color: inherit;
    text-decoration: none;
    padding: 10px 5px;
    display: block;
    margin-left: 16px;
    text-align: center;
    opacity: 0.6;
    transition: opacity 0.15s ease;
  }

  a:hover {
    opacity: 1;
  }

  a.selected {
    opacity: 1;
    color: var(--primary-color);
  }

  a.selected::before {
    content: '[ ';
  }

  a.selected::after {
    content: ' ]';
  }

  .theme-toggle-container {
    width: 75px;
  }

  @media screen and (max-width: 520px) {
    .theme-toggle-container {
      margin-right: 1em;
    }
  }
</style>

<nav>
  <a class={current === '' ? 'selected' : ''} href="/">home</a>
  <a class={current === 'projects' ? 'selected' : ''} href="/projects">code</a>
  <a class={current === 'talks' ? 'selected' : ''} href="/talks">talks</a>
  <a class={current === 'writing' ? 'selected' : ''} href="/writing">writing</a>
  <a href="http://blog.ikotler.org" target="_blank" rel="noopener">blog</a>
  <div class="theme-toggle-container">
    <ThemeToggleButton client:only="svelte" />
  </div>
</nav>
