      },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Writing</h1>
      <p class="subtitle">Articles, publications, and blog posts over the years.</p>
      {
        writing.map((group) => (
          <div class="year-group">
            <h2>{group.year}</h2>
            <ul>
              {group.items.map((item) => (
                <li>
                  {item.url ? (
                    <a href={item.url} target="_blank" rel="noopener">{item.title}</a>
                  ) : (
                    <span>{item.title}</span>
                  )}
                  <span class="venue"> — {item.venue}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </main>
    <Footer />
  </body>
</html>

<style>
  .subtitle {
    color: rgb(var(--gray));
    margin-bottom: 2em;
  }

  .year-group {
    margin-bottom: 2em;
  }

  h2 {
    font-size: 1.3em;
    font-weight: 700;
    margin-bottom: 0.5em;
    margin-top: 0;
    color: rgb(var(--black));
    border-bottom: 1px solid rgb(var(--gray-light));
    padding-bottom: 0.2em;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    padding: 0.3em 0;
    line-height: 1.5;
    padding-left: 1.2em;
    text-indent: -1.2em;
  }

  li::before {
    content: '* ';
    color: rgb(var(--gray));
  }

  .venue {
    color: rgb(var(--gray));
    font-size: 0.9em;
  }
</style>
